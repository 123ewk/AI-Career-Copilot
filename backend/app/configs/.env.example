# ==================== 应用配置 ====================
APP_NAME=AI Career Copilot
APP_ENV=dev
DEBUG=true
LOG_LEVEL=INFO

# ==================== PostgreSQL ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=copilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=copilot_dev

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== RabbitMQ ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==================== JWT ====================
JWT_SECRET_KEY=changeme-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== LLM ====================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
MIMO_API_KEY=
MIMO_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
# 当前使用的 LLM 提供商：deepseek / openai / mimo
LLM_PROVIDER=mimo

# ==================== Tavily Search ====================
TAVILY_API_KEY=
TAVILY_API_BASE=https://api.tavily.com
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
TAVILY_TIMEOUT=15.0
TAVILY_MAX_RETRIES=3

# ==================== 文件上传 ====================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ==================== CORS 跨域 ====================
# 精确白名单：Web 前端、第三方回调等固定域名
# 多个用英文逗号分隔，留空表示不额外放行（dev 环境会自动追加本地端口）
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=

# 是否放行浏览器扩展来源（chrome/moz/edge-extension://*）
# 开发环境：true；生产环境：建议 false 并配合 X-Extension-ID 二次校验
CORS_ALLOW_EXTENSIONS=true

# 是否允许携带 Cookie / Authorization 等凭据
CORS_ALLOW_CREDENTIALS=true

# 预检请求（OPTIONS）结果在浏览器侧缓存秒数
CORS_MAX_AGE_SECONDS=600
